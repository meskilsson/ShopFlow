PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/shopflow
JWT_SECRET=your_test_jwt_secret_here
JWT_EXPIRES_IN=7d
GUEST_COOKIE_NAME=shopflow.guestId

